---
// REQ-LANG-04 - Root redirect to default locale (EN).
// Static-build friendly: meta refresh + JS fallback + canonical hint.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Skydive Luxembourg</title>
    <meta http-equiv="refresh" content="0; url=/en/" />
    <link rel="canonical" href="/en/" />
    <meta name="robots" content="noindex" />
    <script>window.location.replace('/en/');</script>
  </head>
  <body>
    <p>Redirecting to <a href="/en/">/en/</a>…</p>
  </body>
</html>
