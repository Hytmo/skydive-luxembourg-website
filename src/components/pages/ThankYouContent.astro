---
/**
 * ThankYouContent.astro - confirmation page after form submission. Picks copy by `lang` prop.
 */
const { lang = 'en' } = Astro.props;

const t = {
  en: {
    eyebrow: 'Message received',
    title: 'Thank you - we have your message.',
    body: 'We have received your inquiry and a member of our team will get back to you within two to three business days. In high season, expect to hear from us sooner.',
    note: 'In the meantime, blue skies - and feel free to browse around.',
    primary: 'Back to home',
    secondary: 'View FAQ',
  },

  fr: {
    eyebrow: 'Message reçu',
    title: 'Merci - votre message nous est bien parvenu.',
    message: 'Nous avons reçu votre demande. Un membre de l\'équipe vous répondra sous deux jours ouvrés. En pleine saison, nous revenons vers vous plus rapidement.',
    note: 'En attendant, bleu ciel - et n\'hésitez pas à parcourir le site.',
    primary: 'Retour à l\'accueil',
    secondary: 'Voir la FAQ',
  },

  de: {
    eyebrow: 'Nachricht erhalten',
    title: 'Danke - wir haben deine Nachricht.',
    message: 'Wir haben deine Anfrage erhalten. Ein Teammitglied meldet sich innerhalb von zwei Werktagen zurück. In der Hochsaison hörst du in der Regel früher von uns.',
    note: 'Bis dahin: blaue Himmel - schau dich gern auf der Seite um.',
    primary: 'Zur Startseite',
    secondary: 'Zu den FAQ',
  },
}[lang];

const homeHref = `/${lang}/`;
const faqHref = `/${lang}/faq`;
---

<section class="section section--dark thank-you">
  <div class="section__inner section__inner--narrow">
    <div class="thank-you__card">
      <p class="section__eyebrow">{t.eyebrow}</p>
      <h1 class="section__title">{t.title}</h1>
      <p class="section__lead">{t.message}</p>
      <p class="thank-you__note">{t.note}</p>
      <p class="thank-you__actions">
        <a href={homeHref} class="btn btn--primary btn--lg">{t.primary}</a>
        <a href={faqHref} class="btn btn--ghost btn--lg">{t.secondary}</a>
      </p>
    </div>
  </div>
</section>

<style>
  .thank-you {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .thank-you__card {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto;
  }
  .thank-you__note {
    margin-top: var(--space-4);
    opacity: 0.85;
    font-style: italic;
  }
  .thank-you__actions {
    margin-top: var(--space-8);
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
