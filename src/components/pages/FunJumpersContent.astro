---
/**
 * FunJumpersContent.astro - sport jumpers page body. Picks copy by `lang` prop.
 */
import PageBanner from '../sections/PageBanner.astro';
import FeatureCards from '../sections/FeatureCards.astro';
import CTABanner from '../sections/CTABanner.astro';
import FunJumperForm from '../FunJumperForm.astro';

import bannerImg from '../../assets/img/Fun-2.jpg';
import planeImg from '../../assets/img/Hero-3.jpg';
import packingImg from '../../assets/img/Fun-1.jpg';
import briefingImg from '../../assets/img/Fun-3.jpg';
import hangarImg from '../../assets/img/Hero-4.jpg';

const { lang = 'en' } = Astro.props;

const t = {
  en: {
    bannerEyebrow: 'Sport jumpers',
    bannerTitle: 'Welcome to the dropzone.',
    bannerSubtitle: 'Open weekends and public holidays during the season, with an annual jump week and coaching for licensed skydivers.',

    introEyebrow: 'About the DZ',
    introTitle: 'Small dropzone. Big sky.',
    introText: 'Skydive Luxembourg is open every weekend and on public holidays during the season. Once a year, we also organise a jump week, when the club stays open continuously. National championships in 4-way formation skydiving, 2-way formation skydiving, 2-way freefly, speedflying and wingsuit are usually held on the same occasion. The club also organises activities during the year, so check the calendar regularly.',

    facEyebrow: 'Facilities',
    facTitle: 'Everything you need on site.',
    facLead: 'Clean, well-equipped infrastructure so you can focus on jumping.',

    cards: [
      { title: 'GA8 Airvan', text: '4 000 m in about 20 minutes, with 7 places for parachutists.', image: planeImg, alt: 'GA8 Airvan jump aircraft' },
      { title: 'Gear', text: 'Club equipment includes Next, Firebird, Vector 3 and Omega systems, with canopies from 150 to 260 and accessories.', image: packingImg, alt: 'Parachute equipment at the dropzone' },
      { title: 'Coaching', text: 'Instructors are available if you want to develop your skills in the different skydiving disciplines. Please contact us before coming to the DZ.', image: briefingImg, alt: 'Briefing room' },
      { title: 'Infrastructure', text: 'Covered packing area, video briefing and debriefing, bar and showers on site.', image: hangarImg, alt: 'Hangar and clubhouse' },
    ],

    opsEyebrow: 'Operations',
    opsTitle: 'How we run the day.',
    opsLead: 'Please make sure your licence, insurance and documents match the accepted requirements before coming to jump.',
    opsItems: [
      'We usually jump from 4 000 m; the GA8 Airvan reaches altitude in about 20 minutes.',
      'The DZ is open weekends and public holidays during the season, plus the annual jump week.',
      'Coaching is available in different skydiving disciplines, but please contact us before coming to the DZ.',
      'In general, you must have completed basic training (AFF or Static Line).',
      'Accepted licences: Luxembourgish Parachutist Licence; USPA minimum A Licence; DFV (Germany) AFF Ausbildung and minimum 23 jumps; FWCP (Belgium) minimum Brevet A; FFP (France) minimum Brevet B.',
      'Bring your licence, logbook, valid insurance and equipment documents for check-in.',
    ],

    formEyebrow: 'Plan your visit',
    formTitle: 'Plan your visit.',
    formText: 'Fill in the form below to register as a visiting jumper. We\'ll confirm by email within 48 hours.',

    ctaTitle: 'Blue skies and big smiles.',
    ctaSubtitle: 'See you in the manifest queue.',
    ctaPrimary: 'Manifest now',
    ctaSecondary: 'Contact the DZ',
  },

  fr: {
    bannerEyebrow: 'Parachutistes confirmés',
    bannerTitle: 'Bienvenue sur la DZ.',
    bannerSubtitle: 'Ouvert les week-ends et jours fériés pendant la saison, avec une semaine de sauts annuelle et du coaching pour parachutistes brevetés.',

    introEyebrow: 'À propos de la DZ',
    introTitle: 'Petite DZ. Grand ciel.',
    introText: 'Skydive Luxembourg est ouvert tous les week-ends et les jours fériés pendant la saison. Une fois par année, une semaine de sauts est également organisée pendant laquelle le club reste ouvert en continu. Généralement, les championnats nationaux de vol relatif à 4, vol relatif à 2, freefly à 2 et wingsuit ont lieu à la même occasion. Le club organise aussi des activités - consultez régulièrement notre calendrier.',

    facEyebrow: 'Infrastructures',
    facTitle: 'Tout ce qu\'il vous faut sur place.',
    facLead: 'Une infrastructure propre et bien équipée pour vous concentrer sur le saut.',

    cards: [
      { title: 'GA8 Airvan', text: '4 000 m en environ 20 minutes, avec 7 places parachutistes.', image: planeImg, alt: 'Avion GA8 Airvan' },
      { title: 'Matériel', text: 'Le matériel club comprend des systèmes Next, Firebird, Vector 3 et Omega, avec voiles de 150 à 260 et accessoires.', image: packingImg, alt: 'Matériel parachute de la DZ' },
      { title: 'Coaching', text: 'Des instructeurs sont à votre disposition si vous désirez développer vos compétences dans les différentes disciplines du parachutisme. Contactez-nous avant de passer à la DZ.', image: briefingImg, alt: 'Salle de briefing' },
      { title: 'Infrastructure', text: 'Salle de pliage couverte, brief et débrief vidéo, bar et douches sur place.', image: hangarImg, alt: 'Hangar et club-house' },
    ],

    opsEyebrow: 'Opérations',
    opsTitle: 'Comment se déroule la journée.',
    opsLead: 'Vérifiez que votre licence, assurance et documents correspondent aux exigences acceptées avant de venir sauter.',
    opsItems: [
      'Nous sautons généralement de 4 000 m; le GA8 Airvan atteint l’altitude en environ 20 minutes.',
      'La DZ est ouverte les week-ends et jours fériés pendant la saison, ainsi que pendant la semaine de sauts annuelle.',
      'Du coaching est disponible dans différentes disciplines du parachutisme; contactez-nous avant de passer à la DZ.',
      'En général, il faut avoir réussi sa formation de base (AFF ou Static Line) et avoir au minimum 23 sauts.',
      'Licences acceptées : USPA minimum A Licence; DFV (Allemagne) AFF Ausbildung et minimum 23 sauts; FWCP (Belgique) minimum Brevet A; FFP (France) minimum Brevet B.',
      'Présentez votre licence, carnet de sauts, assurance valide et documents matériel lors du check-in.',
    ],

    formEyebrow: 'Préparez votre venue',
    formTitle: 'Manifestez à l\'avance.',
    formText: 'Remplissez le formulaire ci-dessous pour vous enregistrer comme parachutiste visiteur ou réserver un largage. Confirmation par e-mail sous 24 h.',

    ctaTitle: 'Ciels bleus et grands sourires.',
    ctaSubtitle: 'À tout à l\'heure dans la file du manifest.',
    ctaPrimary: 'Manifestez maintenant',
    ctaSecondary: 'Contacter la DZ',
  },

  de: {
    bannerEyebrow: 'Sportspringer',
    bannerTitle: 'Willkommen am Flugplatz.',
    bannerSubtitle: 'Geöffnet an Wochenenden und Feiertagen während der Saison, mit jährlicher Sprungwoche und Coaching für lizenzierte Springer.',

    introEyebrow: 'Über die DZ',
    introTitle: 'Kleine DZ. Großer Himmel.',
    introText: 'Skydive Luxembourg ist während der Saison an Wochenenden und Feiertagen geöffnet. Einmal pro Jahr organisieren wir eine Sprungwoche, in der der Club durchgehend geöffnet bleibt. Die nationalen Meisterschaften in 4er-Formation, 2er-Formation, 2er-Freefly und Wingsuit finden meist bei derselben Gelegenheit statt. Der Club organisiert außerdem Aktivitäten - bitte regelmäßig den Kalender prüfen.',

    facEyebrow: 'Einrichtungen',
    facTitle: 'Alles, was du brauchst, vor Ort.',
    facLead: 'Saubere, gut ausgestattete Infrastruktur, damit du dich aufs Springen konzentrieren kannst.',

    cards: [
      { title: 'GA8 Airvan', text: '4 000 m in etwa 20 Minuten, mit 7 Plätzen für Fallschirmspringer.', image: planeImg, alt: 'GA8 Airvan' },
      { title: 'Material', text: 'Clubmaterial: Next, Firebird, Vector 3 und Omega Systeme, Schirme von 150 bis 260 sowie Zubehör.', image: packingImg, alt: 'Fallschirmausrüstung der DZ' },
      { title: 'Coaching', text: 'Lehrer stehen zur Verfügung, wenn du deine Fähigkeiten in verschiedenen Fallschirmsport-Disziplinen weiterentwickeln möchtest. Bitte kontaktiere uns vor deinem Besuch.', image: briefingImg, alt: 'Briefing-Raum' },
      { title: 'Infrastruktur', text: 'Überdachter Packbereich, Video-Briefing und -Debriefing, Bar und Duschen vor Ort.', image: hangarImg, alt: 'Hangar und Vereinsheim' },
    ],

    opsEyebrow: 'Betrieb',
    opsTitle: 'So läuft der Sprungtag ab.',
    opsLead: 'Bitte stelle sicher, dass Lizenz, Versicherung und Dokumente den akzeptierten Anforderungen entsprechen, bevor du zum Springen kommst.',
    opsItems: [
      'Wir springen normalerweise aus 4 000 m; die GA8 Airvan erreicht die Höhe in etwa 20 Minuten.',
      'Sprungbetrieb an Wochenenden und Feiertagen während der Saison sowie während der jährlichen Sprungwoche.',
      'Coaching ist in verschiedenen Fallschirmsport-Disziplinen möglich; bitte vorher Kontakt aufnehmen.',
      'Grundsätzlich musst du eine Grundausbildung (AFF oder Static Line) abgeschlossen und mindestens 23 Sprünge haben.',
      'Akzeptierte Lizenzen: USPA mindestens A Licence; DFV (Deutschland) AFF Ausbildung und mindestens 23 Sprünge; FWCP (Belgien) mindestens Brevet A; FFP (Frankreich) mindestens Brevet B.',
      'Bring Lizenz, Sprungbuch, gültige Versicherung und Materialdokumente zum Check-in mit.',
    ],

    formEyebrow: 'Plane deinen Besuch',
    formTitle: 'Vorab anmelden.',
    formText: 'Fülle das Formular unten aus, um dich als Gastspringer anzumelden oder eine Last zu reservieren. Bestätigung per E-Mail innerhalb von 24 Stunden.',

    ctaTitle: 'Blauer Himmel und breites Grinsen.',
    ctaSubtitle: 'Wir sehen uns in der Manifest-Schlange.',
    ctaPrimary: 'Jetzt anmelden',
    ctaSecondary: 'DZ kontaktieren',
  },
}[lang];

const contactHref = `/${lang}/contact`;
---

<PageBanner
  image={bannerImg}
  alt="Sport jumpers at the dropzone"
  eyebrow={t.bannerEyebrow}
  title={t.bannerTitle}
  subtitle={t.bannerSubtitle}
/>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.introEyebrow}</p>
      <h2 class="section__title">{t.introTitle}</h2>
      <p class="section__lead">{t.introText}</p>
    </header>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner">
    <header class="section__header">
      <p class="section__eyebrow">{t.facEyebrow}</p>
      <h2 class="section__title">{t.facTitle}</h2>
      <p class="section__lead">{t.facLead}</p>
    </header>
    <FeatureCards items={t.cards} cols={2} />
  </div>
</section>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.opsEyebrow}</p>
      <h2 class="section__title">{t.opsTitle}</h2>
      <p class="section__lead">{t.opsLead}</p>
    </header>
    <div class="ops-box">
      <ul>
        {t.opsItems.map((i) => <li>{i}</li>)}
      </ul>
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.formEyebrow}</p>
      <h2 class="section__title">{t.formTitle}</h2>
      <p class="section__lead">{t.formText}</p>
    </header>
    <FunJumperForm lang={lang} />
  </div>
</section>

<CTABanner
  title={t.ctaTitle}
  subtitle={t.ctaSubtitle}
  primaryCta={{ label: t.ctaPrimary, href: '#funjumper-form' }}
  secondaryCta={{ label: t.ctaSecondary, href: contactHref }}
/>

<style>
  .ops-box {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
  }
  .ops-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .ops-box li {
    padding-left: var(--space-6);
    position: relative;
    color: var(--color-fg-muted);
  }
  .ops-box li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-blue);
    font-weight: var(--fw-bold);
  }
</style>
