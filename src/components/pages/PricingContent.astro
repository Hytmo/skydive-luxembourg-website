---
/**
 * PricingContent.astro — pricing page body. Picks copy by `lang` prop.
 * Prices are copied from the old/current public pricing page:
 * https://www.cerclepara.lu/skydivers/prix/
 */
import PageBanner from '../sections/PageBanner.astro';
import CTABanner from '../sections/CTABanner.astro';

import bannerImg from '../../assets/img/Hero-3.jpg';

const BOOKING_URL = 'https://cpl.dz-cloud.com/en/Booking/s1_Options';

const { lang = 'en' } = Astro.props;

const priceRows = {
  membership: [
    { key: 'withInsurance', price: '300 €' },
    { key: 'withoutInsurance', price: '230 €' },
  ],
  tandem: [
    { key: 'tandemVideo', price: '350 €', featured: true },
    { key: 'tshirt', price: '30 €' },
  ],
  school: [],
  solo: [
    { key: 'member4000', price: '35 €' },
    { key: 'member2000', price: '35 €' },
    { key: 'coached', price: '80 €' },
    { key: 'checkjump', price: '90 €' },
    { key: 'guest4000', price: '43 €' },
    { key: 'guest2000', price: '43 €' },
  ],
  rental: [
    { key: 'rentalMember', price: '15 €' },
    { key: 'rentalGuest', price: '20 €' },
    { key: 'packjob', price: '7 €' },
  ],
};

const labels = {
  en: {
    withInsurance: 'Annual membership — third-party insurance and FAI licence included',
    withoutInsurance: 'Annual membership — without insurance or FAI licence',
    tandemVideo: 'Tandem & video',
    tshirt: 'T-shirt',
    member4000: 'Member jump — 4 000 m',
    member2000: 'Member jump — 2 000 m',
    coached: 'Coached jump — 1 on 1',
    checkjump: 'Check jump',
    guest4000: 'Guest jump — 4 000 m',
    guest2000: 'Guest jump — 2 000 m',
    rentalMember: 'Parachute rental — members',
    rentalGuest: 'Parachute rental — guests',
    packjob: 'Pack job',
    trainingContact: 'AFF / training formula',
  },
  fr: {
    withInsurance: 'Cotisation annuelle — assurance tiers et licence FAI incluses',
    withoutInsurance: 'Cotisation annuelle — sans assurance ni licence FAI',
    tandemVideo: 'Tandem & vidéo',
    tshirt: 'T-shirt',
    member4000: 'Saut membre — 4 000 m',
    member2000: 'Saut membre — 2 000 m',
    coached: 'Saut coaché — 1 on 1',
    checkjump: 'Checkjump',
    guest4000: 'Saut guest — 4 000 m',
    guest2000: 'Saut guest — 2 000 m',
    rentalMember: 'Location parachute — membres',
    rentalGuest: 'Location parachute — guest',
    packjob: 'Packjob',
    trainingContact: 'Formule AFF / formation',
  },
  de: {
    withInsurance: 'Jahresmitgliedschaft — Haftpflichtversicherung und FAI-Lizenz inklusive',
    withoutInsurance: 'Jahresmitgliedschaft — ohne Versicherung und FAI-Lizenz',
    tandemVideo: 'Tandem & Video',
    tshirt: 'T-Shirt',
    member4000: 'Mitgliedersprung — 4 000 m',
    member2000: 'Mitgliedersprung — 2 000 m',
    coached: 'Coach-Sprung — 1 on 1',
    checkjump: 'Checkjump',
    guest4000: 'Gastsprung — 4 000 m',
    guest2000: 'Gastsprung — 2 000 m',
    rentalMember: 'Fallschirmmiete — Mitglieder',
    rentalGuest: 'Fallschirmmiete — Gäste',
    packjob: 'Packjob',
    trainingContact: 'AFF- / Ausbildungsformel',
  },
}[lang];

const t = {
  en: {
    bannerEyebrow: 'Prices',
    bannerTitle: 'Current club formulas.',
    bannerSubtitle: 'The formulas below are copied from the current published Skydive Luxembourg tariff page — no invented packages, no fake upsells.',
    introEyebrow: 'Tariffs',
    introTitle: 'Simple prices for members, guests and tandem passengers.',
    introText: 'All prices are the current published club prices. Écolage/training does not currently list a public price on the old site, so it is shown as contact-first instead of guessing.',
    sourceText: 'Source: current old-site pricing page checked during rebuild.',
    ctaTitle: 'Questions about a formula?',
    ctaSubtitle: 'Write to us before booking — especially for training, licences, guest jumps or equipment rental.',
    ctaPrimary: 'Book a tandem',
    ctaSecondary: 'Contact us',
    contact: 'Ask us',
    onRequest: 'On request',
    sections: {
      membership: { eyebrow: 'Membership', title: 'Become a member', description: 'Annual club membership options.' },
      tandem: { eyebrow: 'Tandem jumps', title: 'Tandem formulas', description: 'Current tandem package and T-shirt price.' },
      school: { eyebrow: 'Training', title: 'Écolage', description: 'No public training price is listed on the old tariff page. Contact us for the current AFF/training formula.' },
      solo: { eyebrow: 'Solo skydivers', title: 'Jump tickets', description: 'Member, guest, coached and check-jump prices.' },
      rental: { eyebrow: 'Rental', title: 'Gear and packing', description: 'Rental and pack-job prices.' },
    },
  },
  fr: {
    bannerEyebrow: 'Tarifs',
    bannerTitle: 'Les formules actuelles du club.',
    bannerSubtitle: 'Les formules ci-dessous reprennent les prix actuellement publiés sur l’ancien site Skydive Luxembourg — pas de forfaits inventés.',
    introEyebrow: 'Tarifs',
    introTitle: 'Des prix simples pour membres, guests et passagers tandem.',
    introText: 'Tous les montants sont les prix actuellement publiés par le club. L’écolage/la formation n’affiche pas de prix public sur l’ancien site; nous l’indiquons donc sur demande au lieu d’inventer un tarif.',
    sourceText: 'Source : page tarifs actuelle de l’ancien site, vérifiée pendant la reconstruction.',
    ctaTitle: 'Une question sur une formule ?',
    ctaSubtitle: 'Contactez-nous avant de réserver — surtout pour la formation, les licences, les sauts guest ou la location de matériel.',
    ctaPrimary: 'Réserver un tandem',
    ctaSecondary: 'Nous contacter',
    contact: 'Nous demander',
    onRequest: 'Sur demande',
    sections: {
      membership: { eyebrow: 'Membres', title: 'Devenir membre', description: 'Options de cotisation annuelle du club.' },
      tandem: { eyebrow: 'Sauts en tandem', title: 'Formules tandem', description: 'Forfait tandem actuel et prix du T-shirt.' },
      school: { eyebrow: 'Formation', title: 'Écolage', description: 'Aucun prix de formation public n’est indiqué sur l’ancienne page tarifs. Contactez-nous pour la formule AFF/formation actuelle.' },
      solo: { eyebrow: 'Solo skydivers', title: 'Tickets de saut', description: 'Prix membres, guests, sauts coachés et checkjumps.' },
      rental: { eyebrow: 'Location', title: 'Matériel et pliage', description: 'Prix de location et de packjob.' },
    },
  },
  de: {
    bannerEyebrow: 'Preise',
    bannerTitle: 'Die aktuellen Club-Formeln.',
    bannerSubtitle: 'Die Formeln unten übernehmen die aktuell veröffentlichten Preise der alten Skydive-Luxembourg-Seite — keine erfundenen Pakete.',
    introEyebrow: 'Tarife',
    introTitle: 'Klare Preise für Mitglieder, Gäste und Tandempassagiere.',
    introText: 'Alle Beträge sind die aktuell veröffentlichten Clubpreise. Für Écolage/Ausbildung steht auf der alten Seite kein öffentlicher Preis; deshalb zeigen wir hier Kontakt statt Fantasiepreis.',
    sourceText: 'Quelle: aktuelle Preisseite der alten Website, während des Rebuilds geprüft.',
    ctaTitle: 'Frage zu einer Formel?',
    ctaSubtitle: 'Schreib uns vor der Buchung — besonders bei Ausbildung, Lizenzen, Gastsprüngen oder Materialmiete.',
    ctaPrimary: 'Tandem buchen',
    ctaSecondary: 'Kontakt',
    contact: 'Anfragen',
    onRequest: 'Auf Anfrage',
    sections: {
      membership: { eyebrow: 'Mitgliedschaft', title: 'Mitglied werden', description: 'Jährliche Club-Mitgliedschaften.' },
      tandem: { eyebrow: 'Tandemsprünge', title: 'Tandem-Formeln', description: 'Aktuelles Tandempaket und T-Shirt-Preis.' },
      school: { eyebrow: 'Ausbildung', title: 'Écolage', description: 'Auf der alten Preisseite ist kein öffentlicher Ausbildungspreis angegeben. Kontaktiere uns für die aktuelle AFF-/Ausbildungsformel.' },
      solo: { eyebrow: 'Solo skydivers', title: 'Sprungtickets', description: 'Preise für Mitglieder, Gäste, Coach-Sprünge und Checkjumps.' },
      rental: { eyebrow: 'Miete', title: 'Material und Packen', description: 'Preise für Materialmiete und Packjob.' },
    },
  },
}[lang];

const contactHref = `/${lang}/contact`;

const cards = [
  { id: 'membership', rows: priceRows.membership, cta: { label: t.contact, href: contactHref } },
  { id: 'tandem', rows: priceRows.tandem, cta: { label: t.ctaPrimary, href: BOOKING_URL }, highlighted: true },
  { id: 'school', rows: [{ key: 'trainingContact', price: t.onRequest }], cta: { label: t.contact, href: `/${lang}/aff` } },
  { id: 'solo', rows: priceRows.solo, cta: { label: t.contact, href: `/${lang}/fun-jumpers` } },
  { id: 'rental', rows: priceRows.rental, cta: { label: t.contact, href: contactHref } },
];
---

<PageBanner
  image={bannerImg}
  alt="Skydivers above Luxembourg"
  eyebrow={t.bannerEyebrow}
  title={t.bannerTitle}
  subtitle={t.bannerSubtitle}
/>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.introEyebrow}</p>
      <h2 class="section__title">{t.introTitle}</h2>
      <p class="section__lead">{t.introText}</p>
      <p class="tariff-source">{t.sourceText}</p>
    </header>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner">
    <div class="tariff-grid">
      {cards.map((card) => {
        const section = t.sections[card.id];
        return (
          <article class={`tariff-card${card.highlighted ? ' tariff-card--highlighted' : ''}`}>
            <div class="tariff-card__header">
              <p class="tariff-card__eyebrow">{section.eyebrow}</p>
              <h2>{section.title}</h2>
              <p>{section.description}</p>
            </div>

            {card.rows.length > 0 ? (
              <dl class="tariff-list">
                {card.rows.map((row) => (
                  <div class={`tariff-row${row.featured ? ' tariff-row--featured' : ''}`}>
                    <dt>{labels[row.key]}</dt>
                    <dd>{row.price}</dd>
                  </div>
                ))}
              </dl>
            ) : (
              <div class="tariff-empty">
                <p>{section.description}</p>
              </div>
            )}

            {card.cta && (
              <a
                href={card.cta.href}
                class={`btn ${card.highlighted ? 'btn--primary' : 'btn--outline'}`}
                {...(card.cta.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {card.cta.label}
              </a>
            )}
          </article>
        );
      })}
    </div>
  </div>
</section>

<CTABanner
  title={t.ctaTitle}
  subtitle={t.ctaSubtitle}
  primaryCta={{ label: t.ctaPrimary, href: BOOKING_URL }}
  secondaryCta={{ label: t.ctaSecondary, href: contactHref }}
/>

<style>
  .tariff-source {
    margin-top: var(--space-4);
    color: var(--color-fg-muted);
    font-size: var(--fs-sm);
  }

  .tariff-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
    align-items: start;
  }

  .tariff-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    box-shadow: var(--shadow-sm);
  }

  .tariff-card--highlighted {
    border-color: var(--color-cta);
    box-shadow: var(--shadow-lg);
  }

  .tariff-card__header {
    display: grid;
    gap: var(--space-2);
  }

  .tariff-card__eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tariff-card__header h2 {
    font-size: var(--fs-2xl);
    margin: 0;
  }

  .tariff-card__header p:last-child,
  .tariff-empty p {
    margin: 0;
    color: var(--color-fg-muted);
  }

  .tariff-list {
    margin: 0;
    display: grid;
    gap: var(--space-3);
    align-content: start;
  }

  .tariff-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-alt);
  }

  .tariff-row--featured {
    border-color: var(--color-cta);
    background: color-mix(in srgb, var(--color-cta) 8%, var(--color-bg));
  }

  .tariff-row dt {
    font-weight: var(--fw-medium);
  }

  .tariff-row dd {
    margin: 0;
    font-size: var(--fs-2xl);
    font-weight: var(--fw-bold);
    color: var(--color-fg);
    white-space: nowrap;
  }

  .tariff-empty {
    flex: 1;
    padding: var(--space-5);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-alt);
  }

  .tariff-card .btn {
    width: 100%;
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .tariff-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .tariff-card {
      padding: var(--space-6);
    }

    .tariff-row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
