---

<PageBanner
  image={bannerImg}
  alt="Skydivers above Luxembourg"
  eyebrow={t.bannerEyebrow}
  title={t.bannerTitle}
  subtitle={t.bannerSubtitle}
/>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.introEyebrow}</p>
      <h2 class="section__title">{t.introTitle}</h2>
      <p class="section__lead">{t.introText}</p>
    </header>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner">
    <header class="section__header">
      <p class="section__eyebrow">{t.tandemEyebrow}</p>
      <h2 class="section__title">{t.tandemTitle}</h2>
      <p class="section__lead">{t.tandemLead}</p>
    </header>
    <PriceCards items={t.tandemCards} />
  </div>
</section>

<section class="section">
  <div class="section__inner">
    <header class="section__header">
      <p class="section__eyebrow">{t.affEyebrow}</p>
      <h2 class="section__title">{t.affTitle}</h2>
      <p class="section__lead">{t.affLead}</p>
    </header>
    <PriceCards items={t.affCards} />
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner">
    <header class="section__header">
      <p class="section__eyebrow">{t.funEyebrow}</p>
      <h2 class="section__title">{t.funTitle}</h2>
      <p class="section__lead">{t.funLead}</p>
    </header>
    <PriceCards items={t.funCards} />
  </div>
</section>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.notesEyebrow}</p>
      <h2 class="section__title">{t.notesTitle}</h2>
    </header>
    <div class="grid grid--2">
      <div class="notes-box">
        <h3>{t.includedTitle}</h3>
        <ul>
          {t.included.map((i) => <li>{i}</li>)}
        </ul>
      </div>
      <div class="notes-box notes-box--excl">
        <h3>{t.excludedTitle}</h3>
        <ul>
          {t.excluded.map((i) => <li>{i}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<CTABanner
  title={t.ctaTitle}
  subtitle={t.ctaSubtitle}
  primaryCta={{ label: t.ctaPrimary, href: BOOKING_URL }}
  secondaryCta={{ label: t.ctaSecondary, href: contactHref }}
/>

<style>
  .notes-box {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
  }
  .notes-box h3 {
    margin-bottom: var(--space-4);
    font-size: var(--fs-lg);
  }
  .notes-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .notes-box li {
    padding-left: var(--space-6);
    position: relative;
    color: var(--color-fg-muted);
  }
  .notes-box li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-blue);
    font-weight: var(--fw-bold);
  }
  .notes-box--excl li::before {
    content: '–';
    color: var(--color-red, var(--color-fg-muted));
  }
</style>
