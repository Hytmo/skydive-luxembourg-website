---
/**
 * PricingContent.astro - pricing page body. Picks copy by `lang` prop.
 * Club formulas: old/current public pricing page plus confirmed AFF price from Fränz.
 */
import PageBanner from '../sections/PageBanner.astro';
import CTABanner from '../sections/CTABanner.astro';

import bannerImg from '../../assets/img/Hero-3.jpg';

const BOOKING_URL = 'https://cpl.dz-cloud.com/en/Booking/s1_Options';

const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    affFormula: 'AFF course',
    tandemVideo: 'Tandem & video',
    tshirt: 'T-shirt',
    withInsurance: 'Annual membership - third-party insurance and FAI licence included',
    withoutInsurance: 'Annual membership - without insurance or FAI licence',
    member4000: 'Member jump - 4 000 m',
    member2000: 'Member jump - 2 000 m',
    coached: 'Coached jump - 1 on 1',
    checkjump: 'Check jump',
    guest4000: 'Guest jump - 4 000 m',
    guest2000: 'Guest jump - 2 000 m',
    rentalMember: 'Parachute rental - members',
    rentalGuest: 'Parachute rental - guests',
    packjob: 'Pack job',
  },
  fr: {
    affFormula: 'Cours AFF',
    tandemVideo: 'Tandem & vidéo',
    tshirt: 'T-shirt',
    withInsurance: 'Cotisation annuelle - assurance tiers et licence FAI incluses',
    withoutInsurance: 'Cotisation annuelle - sans assurance ni licence FAI',
    member4000: 'Saut membre - 4 000 m',
    member2000: 'Saut membre - 2 000 m',
    coached: 'Saut coaché - 1 pour 1',
    checkjump: 'Saut de contrôle',
    guest4000: 'Saut visiteur - 4 000 m',
    guest2000: 'Saut visiteur - 2 000 m',
    rentalMember: 'Location parachute - membres',
    rentalGuest: 'Location parachute - visiteurs',
    packjob: 'Pliage',
  },
  de: {
    affFormula: 'AFF-Kurs',
    tandemVideo: 'Tandem & Video',
    tshirt: 'T-Shirt',
    withInsurance: 'Jahresmitgliedschaft - Haftpflichtversicherung und FAI-Lizenz inklusive',
    withoutInsurance: 'Jahresmitgliedschaft - ohne Versicherung und FAI-Lizenz',
    member4000: 'Mitgliedersprung - 4 000 m',
    member2000: 'Mitgliedersprung - 2 000 m',
    coached: 'Coach-Sprung - 1 zu 1',
    checkjump: 'Checksprung',
    guest4000: 'Gastsprung - 4 000 m',
    guest2000: 'Gastsprung - 2 000 m',
    rentalMember: 'Fallschirmmiete - Mitglieder',
    rentalGuest: 'Fallschirmmiete - Gäste',
    packjob: 'Packen',
  },
}[lang];

const t = {
  en: {
    bannerEyebrow: 'Prices',
    bannerTitle: 'Current club formulas.',
    bannerSubtitle: 'AFF and tandem first, then club prices for members, guests, rental and packing.',
    introEyebrow: 'Prices',
    introTitle: 'Main formulas at a glance.',
    introText: 'AFF and tandem are shown first, followed by the current club prices for members, guests, rental and packing.',
    sourceText: '',
    affNote: 'Training formula',
    tandemNote: 'Most common first-jump formula',
    primaryAction: 'Ask about AFF',
    tandemAction: 'Book a tandem',
    ctaTitle: 'Questions about a formula?',
    ctaSubtitle: 'Write to us before booking, especially for training, licences, guest jumps or equipment rental.',
    ctaSecondary: 'Contact us',
    sections: {
      membership: { eyebrow: 'Membership', title: 'Become a member', description: 'Annual club membership options.' },
      solo: { eyebrow: 'Solo skydivers', title: 'Jump tickets', description: 'Member, guest, coached and check-jump prices.' },
      rental: { eyebrow: 'Rental', title: 'Gear and packing', description: 'Rental and pack-job prices.' },
    },
  },
  fr: {
    bannerEyebrow: 'Tarifs',
    bannerTitle: 'Les formules actuelles du club.',
    bannerSubtitle: 'AFF et tandem d’abord, puis les tarifs du club pour membres, visiteurs, location et pliage.',
    introEyebrow: 'Tarifs',
    introTitle: 'Les formules principales en un coup d’œil.',
    introText: 'AFF et tandem sont affichés d’abord, suivis des tarifs actuels du club pour membres, visiteurs, location et pliage.',
    sourceText: '',
    affNote: 'Formule formation',
    tandemNote: 'Formule premier saut la plus demandée',
    primaryAction: 'Demander l’AFF',
    tandemAction: 'Réserver un tandem',
    ctaTitle: 'Une question sur une formule ?',
    ctaSubtitle: 'Écrivez-nous avant de réserver, surtout pour la formation, les licences, les sauts visiteurs ou la location de matériel.',
    ctaSecondary: 'Nous contacter',
    sections: {
      membership: { eyebrow: 'Membres', title: 'Devenir membre', description: 'Options de cotisation annuelle du club.' },
      solo: { eyebrow: 'Parachutistes solo', title: 'Tickets de saut', description: 'Prix membres, visiteurs, sauts coachés et sauts de contrôle.' },
      rental: { eyebrow: 'Location', title: 'Matériel et pliage', description: 'Prix de location et de pliage.' },
    },
  },
  de: {
    bannerEyebrow: 'Preise',
    bannerTitle: 'Die aktuellen Club-Formeln.',
    bannerSubtitle: 'AFF und Tandem zuerst, danach die aktuellen Clubpreise für Mitglieder, Gäste, Miete und Packen.',
    introEyebrow: 'Preise',
    introTitle: 'Die wichtigsten Formeln auf einen Blick.',
    introText: 'AFF und Tandem stehen zuerst, danach folgen die aktuellen Clubpreise für Mitglieder, Gäste, Materialmiete und Packen.',
    sourceText: '',
    affNote: 'Ausbildungsformel',
    tandemNote: 'Häufigste Erst-Sprung-Formel',
    primaryAction: 'AFF anfragen',
    tandemAction: 'Tandem buchen',
    ctaTitle: 'Frage zu einer Formel?',
    ctaSubtitle: 'Schreib uns vor der Buchung - besonders bei Ausbildung, Lizenzen, Gastsprüngen oder Materialmiete.',
    ctaSecondary: 'Kontakt',
    sections: {
      membership: { eyebrow: 'Mitgliedschaft', title: 'Mitglied werden', description: 'Jährliche Club-Mitgliedschaften.' },
      solo: { eyebrow: 'Solo-Springer', title: 'Sprungtickets', description: 'Preise für Mitglieder, Gäste, Coach-Sprünge und Checksprünge.' },
      rental: { eyebrow: 'Miete', title: 'Material und Packen', description: 'Preise für Materialmiete und Packjob.' },
    },
  },
}[lang];

const contactHref = `/${lang}/contact`;
const affHref = `/${lang}/aff`;
const funJumpersHref = `/${lang}/fun-jumpers`;

const featured = [
  {
    id: 'aff',
    eyebrow: 'AFF',
    title: labels.affFormula,
    price: '2 500 €',
    note: t.affNote,
    href: affHref,
    cta: t.primaryAction,
    variant: 'dark',
  },
  {
    id: 'tandem',
    eyebrow: 'Tandem',
    title: labels.tandemVideo,
    price: '350 €',
    note: t.tandemNote,
    href: BOOKING_URL,
    cta: t.tandemAction,
    variant: 'light',
  },
];

const detailCards = [
  {
    id: 'membership',
    rows: [
      { key: 'withInsurance', price: '300 €' },
      { key: 'withoutInsurance', price: '230 €' },
    ],
    href: contactHref,
  },
  {
    id: 'solo',
    rows: [
      { key: 'member4000', price: '35 €' },
      { key: 'member2000', price: '35 €' },
      { key: 'coached', price: '80 €' },
      { key: 'checkjump', price: '90 €' },
      { key: 'guest4000', price: '43 €' },
      { key: 'guest2000', price: '43 €' },
    ],
    href: funJumpersHref,
  },
  {
    id: 'rental',
    rows: [
      { key: 'tshirt', price: '30 €' },
      { key: 'rentalMember', price: '15 €' },
      { key: 'rentalGuest', price: '20 €' },
      { key: 'packjob', price: '7 €' },
    ],
    href: contactHref,
  },
];
---

<PageBanner
  image={bannerImg}
  alt="Skydivers above Luxembourg"
  imagePosition="center 42%"
  eyebrow={t.bannerEyebrow}
  title={t.bannerTitle}
  subtitle={t.bannerSubtitle}
/>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.introEyebrow}</p>
      <h2 class="section__title">{t.introTitle}</h2>
      <p class="section__lead">{t.introText}</p>
      {t.sourceText && <p class="tariff-source">{t.sourceText}</p>}
    </header>
  </div>
</section>

<section class="section section--alt pricing-section">
  <div class="section__inner">
    <div class="featured-prices">
      {featured.map((item) => (
        <article class={`formula-card formula-card--${item.variant}`}>
          <div>
            <p class="formula-card__eyebrow">{item.eyebrow}</p>
            <h2>{item.title}</h2>
            <p>{item.note}</p>
          </div>
          <p class="formula-card__price">{item.price}</p>
          <a
            href={item.href}
            class={`btn ${item.variant === 'dark' ? 'btn--primary' : 'btn--outline'}`}
            {...(item.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {item.cta}
          </a>
        </article>
      ))}
    </div>

    <div class="detail-prices">
      {detailCards.map((card) => {
        const section = t.sections[card.id];
        return (
          <article class="detail-card">
            <header class="detail-card__header">
              <p class="detail-card__eyebrow">{section.eyebrow}</p>
              <h2>{section.title}</h2>
              <p>{section.description}</p>
            </header>
            <dl class="tariff-list">
              {card.rows.map((row) => (
                <div class="tariff-row">
                  <dt>{labels[row.key]}</dt>
                  <dd>{row.price}</dd>
                </div>
              ))}
            </dl>
            <a href={card.href} class="detail-card__link">{t.ctaSecondary} →</a>
          </article>
        );
      })}
    </div>
  </div>
</section>

<CTABanner
  title={t.ctaTitle}
  subtitle={t.ctaSubtitle}
  primaryCta={{ label: t.tandemAction, href: BOOKING_URL }}
  secondaryCta={{ label: t.ctaSecondary, href: contactHref }}
/>

<style>
  .tariff-source {
    margin-top: var(--space-4);
    color: var(--color-fg-muted);
    font-size: var(--fs-sm);
  }

  .pricing-section {
    padding-top: var(--space-8);
  }

  .pricing-section :global(.section__inner) {
    display: grid;
    gap: var(--space-8);
  }

  .featured-prices {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .formula-card {
    position: relative;
    overflow: hidden;
    min-height: 340px;
    padding: clamp(var(--space-8), 4vw, var(--space-12));
    border-radius: var(--radius-lg, 24px);
    display: grid;
    align-content: space-between;
    gap: var(--space-8);
    box-shadow: rgba(50, 50, 93, 0.25) 0 30px 45px -30px, rgba(0, 0, 0, 0.1) 0 18px 36px -18px;
  }

  .formula-card--dark {
    color: white;
    background:
      radial-gradient(circle at 90% 10%, rgba(249, 107, 238, 0.35), transparent 32%),
      linear-gradient(135deg, #061b31 0%, #1c1e54 56%, #533afd 130%);
  }

  .formula-card--light {
    color: var(--color-fg);
    background:
      radial-gradient(circle at 88% 12%, color-mix(in srgb, var(--color-cta) 24%, transparent), transparent 34%),
      linear-gradient(145deg, color-mix(in srgb, var(--color-cta) 7%, var(--color-bg)) 0%, var(--color-bg) 48%),
      var(--color-bg);
    border: 1px solid color-mix(in srgb, var(--color-cta) 24%, var(--color-border));
  }

  .formula-card__eyebrow,
  .detail-card__eyebrow {
    margin: 0 0 var(--space-3);
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .formula-card__eyebrow {
    color: color-mix(in srgb, currentColor 72%, transparent);
  }

  .formula-card h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .formula-card p:not(.formula-card__price) {
    margin: var(--space-3) 0 0;
    max-width: 34rem;
    color: color-mix(in srgb, currentColor 72%, transparent);
    font-size: var(--fs-lg);
  }

  .formula-card__price {
    margin: 0;
    font-size: clamp(3.75rem, 9vw, 6.5rem);
    font-weight: var(--fw-bold);
    line-height: 0.88;
    letter-spacing: -0.07em;
    font-variant-numeric: tabular-nums;
  }

  .formula-card .btn {
    justify-self: start;
    min-width: 12rem;
  }

  .formula-card--dark .btn--primary {
    background: white;
    border-color: white;
    color: #061b31;
  }

  .detail-prices {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-7);
    align-items: stretch;
  }

  .detail-card {
    margin: var(--space-2);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-10) var(--space-8) var(--space-8);
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--space-7);
    box-shadow: var(--shadow-sm);
  }

  .detail-card__header {
    display: grid;
    gap: var(--space-2);
    padding-top: var(--space-2);
  }

  .detail-card__eyebrow {
    color: var(--color-blue);
  }

  .detail-card__header h2 {
    margin: 0;
    font-size: var(--fs-2xl);
  }

  .detail-card__header p {
    margin: 0;
    color: var(--color-fg-muted);
  }

  .tariff-list {
    margin: 0;
    display: grid;
    align-content: start;
    gap: var(--space-3);
  }

  .tariff-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-4);
    align-items: baseline;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .tariff-row:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .tariff-row dt {
    color: var(--color-fg-muted);
    font-weight: var(--fw-medium);
  }

  .tariff-row dd {
    margin: 0;
    color: var(--color-fg);
    font-size: var(--fs-xl);
    font-weight: var(--fw-bold);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .detail-card__link {
    color: var(--color-cta);
    font-weight: var(--fw-bold);
    text-decoration: none;
  }

  .detail-card__link:hover {
    text-decoration: underline;
  }

  @media (max-width: 980px) {
    .featured-prices,
    .detail-prices {
      grid-template-columns: 1fr;
    }

    .formula-card {
      min-height: 280px;
    }
  }

  @media (max-width: 560px) {
    .formula-card,
    .detail-card {
      padding: var(--space-6);
    }

    .formula-card__price {
      font-size: clamp(3rem, 18vw, 4.5rem);
    }

    .tariff-row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
