---
/**
 * AboutContent.astro — about page body. Picks copy by `lang` prop.
 */
import PageBanner from '../sections/PageBanner.astro';
import FeatureCards from '../sections/FeatureCards.astro';
import CTABanner from '../sections/CTABanner.astro';

import bannerImg from '../../assets/img/Hero-2.jpg';
import tandemImg from '../../assets/img/Tandem-3.jpg';
import affImg from '../../assets/img/AFF-2.jpg';
import funImg from '../../assets/img/Fun-3.jpg';

const { lang = 'en' } = Astro.props;

const t = {
  en: {
    bannerEyebrow: 'About us',
    bannerTitle: 'A non-profit club, run by jumpers, for jumpers.',
    bannerSubtitle: 'Skydive Luxembourg a.s.b.l. — the Grand Duchy\'s only registered parachute club.',

    introEyebrow: 'Who we are',
    introTitle: 'Sixty years of parachuting in the Grand Duchy.',
    introText: 'Skydive Luxembourg a.s.b.l. is a non-profit association founded in 1965 by a handful of passionate parachutists. Today we are still volunteer-run and member-owned, with no shareholders and no dividends — every euro we take in goes back into safer gear, better training, and more lift capacity for our members. We are recognised by the Aéro-Sport Luxembourg and operate under the rules of the Fédération Aéronautique Internationale.',

    whatEyebrow: 'What we do',
    whatTitle: 'Three activities, one community.',
    whatLead: 'We welcome complete beginners, students working towards their licence, and experienced jumpers from across Europe.',

    cards: [
      { title: 'Tandem skydives', text: 'First-jump experiences for anyone aged 16 and over. A short briefing, then a freefall from 4,000 metres harnessed to a qualified tandem master.', image: tandemImg, alt: 'Tandem skydive in freefall' },
      { title: 'AFF student training', text: 'Our Accelerated Freefall course is the modern, fast-track route to a solo skydiving licence. Seven levels of one-on-one instruction with two jumpmasters on your first dives.', image: affImg, alt: 'AFF student under canopy' },
      { title: 'Sport jumpers', text: 'Licensed parachutists are welcome to manifest on our Cessna 208 Caravan. Wing-loading checks, formation coaching and friendly hosts every weekend in season.', image: funImg, alt: 'Sport jumpers exiting the aircraft' },
    ],

    historyEyebrow: 'Our history',
    historyTitle: 'From round canopies to ram-airs.',
    historyText: 'The club\'s first jumps were made in 1965 from a borrowed Cessna with surplus military round parachutes. We moved to our current grass airfield in 1982, took delivery of our first turbine aircraft in 2003, and welcomed our 10,000th tandem passenger in 2019. Through it all, the club has remained a volunteer-run association — instructors, riggers, pilots and ground crew all give their time so that more people can experience the freedom of flight.',

    ethosEyebrow: 'Our ethos',
    ethosTitle: 'Safety first. Fun a very close second.',
    ethosText: 'We believe skydiving should be accessible, well-taught, and joyful. Our gear is maintained to the highest European standards, our instructors hold current international ratings, and our briefings never get cut short. We treat every visitor — first-timer or 5,000-jump wonder — as part of the family from the moment they step onto the dropzone.',

    ctaTitle: 'Come and meet us.',
    ctaSubtitle: 'The clubhouse door is open every weekend from April to October. Drop in for a coffee, a chat, or your first jump.',
    ctaPrimary: 'Book a tandem',
    ctaSecondary: 'Contact us',
  },

  fr: {
    bannerEyebrow: 'À propos',
    bannerTitle: 'Une association sans but lucratif, gérée par et pour les parachutistes.',
    bannerSubtitle: 'Skydive Luxembourg a.s.b.l. — le seul club de parachutisme déclaré du Grand-Duché.',

    introEyebrow: 'Qui sommes-nous',
    introTitle: 'Soixante ans de parachutisme au Grand-Duché.',
    introText: 'Skydive Luxembourg a.s.b.l. est une association sans but lucratif fondée en 1965 par quelques passionnés. Le club reste aujourd\'hui géré par des bénévoles et appartient à ses membres : pas d\'actionnaires, pas de dividendes — chaque euro perçu est réinvesti dans du matériel plus sûr, une meilleure formation et davantage de capacité de largage pour nos membres. Nous sommes reconnus par l\'Aéro-Sport Luxembourg et opérons selon les règles de la Fédération Aéronautique Internationale.',

    whatEyebrow: 'Nos activités',
    whatTitle: 'Trois activités, une seule communauté.',
    whatLead: 'Nous accueillons les débutants complets, les élèves en formation et les parachutistes confirmés venus de toute l\'Europe.',

    cards: [
      { title: 'Sauts en tandem', text: 'Le saut découverte pour toute personne dès 16 ans. Un bref briefing, puis une chute libre depuis 4 000 mètres harnaché à un moniteur tandem qualifié.', image: tandemImg, alt: 'Saut en tandem en chute libre' },
      { title: 'Formation AFF', text: 'Notre stage AFF est la voie moderne et rapide vers le brevet de parachutiste autonome. Sept niveaux d\'instruction individualisée, avec deux moniteurs sur vos premiers sauts.', image: affImg, alt: 'Élève AFF sous voile' },
      { title: 'Parachutistes brevetés', text: 'Les parachutistes confirmés sont les bienvenus à bord de notre Cessna 208 Caravan. Contrôle des voiles, coaching de relatif et accueil chaleureux chaque week-end en saison.', image: funImg, alt: 'Parachutistes confirmés à la sortie de l\'avion' },
    ],

    historyEyebrow: 'Notre histoire',
    historyTitle: 'Des voiles rondes aux ailes modernes.',
    historyText: 'Les premiers sauts du club ont eu lieu en 1965 depuis un Cessna emprunté, sous des voiles rondes issues du surplus militaire. Nous avons rejoint notre aérodrome actuel en 1982, accueilli notre premier avion à turbine en 2003 et célébré notre 10 000ᵉ passager tandem en 2019. Tout au long de cette aventure, le club est resté une association de bénévoles : moniteurs, plieurs, pilotes et équipe au sol donnent tous de leur temps pour que toujours plus de personnes découvrent la liberté du vol.',

    ethosEyebrow: 'Notre philosophie',
    ethosTitle: 'La sécurité d\'abord. Le plaisir juste après.',
    ethosText: 'Nous croyons que le parachutisme doit être accessible, bien enseigné et joyeux. Notre matériel est entretenu selon les standards européens les plus exigeants, nos moniteurs détiennent des qualifications internationales à jour, et nous ne bâclons jamais un briefing. Chaque visiteur — qu\'il en soit à son premier saut ou à son 5 000ᵉ — fait partie de la famille dès qu\'il pose le pied sur la DZ.',

    ctaTitle: 'Venez nous rencontrer.',
    ctaSubtitle: 'Le club-house est ouvert chaque week-end d\'avril à octobre. Passez prendre un café, discuter ou faire votre premier saut.',
    ctaPrimary: 'Réserver un tandem',
    ctaSecondary: 'Nous contacter',
  },

  de: {
    bannerEyebrow: 'Über uns',
    bannerTitle: 'Ein gemeinnütziger Verein — von Springern, für Springer.',
    bannerSubtitle: 'Skydive Luxembourg a.s.b.l. — der einzige eingetragene Fallschirmverein des Großherzogtums.',

    introEyebrow: 'Wer wir sind',
    introTitle: 'Sechzig Jahre Fallschirmsport im Großherzogtum.',
    introText: 'Skydive Luxembourg a.s.b.l. ist ein 1965 von einer Handvoll begeisterter Fallschirmspringer gegründeter, gemeinnütziger Verein. Wir werden bis heute ehrenamtlich geführt und gehören unseren Mitgliedern — es gibt keine Aktionäre und keine Dividenden. Jeder eingenommene Euro fließt zurück in sichereres Material, bessere Ausbildung und mehr Sprungkapazität für unsere Mitglieder. Wir sind von Aéro-Sport Luxembourg anerkannt und arbeiten nach den Regeln der Fédération Aéronautique Internationale.',

    whatEyebrow: 'Was wir tun',
    whatTitle: 'Drei Aktivitäten, eine Gemeinschaft.',
    whatLead: 'Wir empfangen blutige Anfänger, Schüler in der Lizenzausbildung und erfahrene Springer aus ganz Europa.',

    cards: [
      { title: 'Tandemsprünge', text: 'Erstsprung-Erlebnisse ab 16 Jahren. Ein kurzes Briefing, dann freier Fall aus 4 000 Metern, angeschnallt an einen geprüften Tandemmaster.', image: tandemImg, alt: 'Tandemsprung im freien Fall' },
      { title: 'AFF-Ausbildung', text: 'Unser Accelerated-Freefall-Kurs ist der moderne, schnelle Weg zur Solo-Sprunglizenz. Sieben Stufen Einzelunterricht, mit zwei Lehrern auf den ersten Sprüngen.', image: affImg, alt: 'AFF-Schüler am offenen Schirm' },
      { title: 'Sportspringer', text: 'Lizenzierte Fallschirmspringer sind in unserer Cessna 208 Caravan herzlich willkommen. Schirmkontrolle, Formations-Coaching und freundliche Gastgeber an jedem Wochenende der Saison.', image: funImg, alt: 'Sportspringer beim Ausstieg' },
    ],

    historyEyebrow: 'Unsere Geschichte',
    historyTitle: 'Von Rundkappen zu Flächenschirmen.',
    historyText: 'Die ersten Sprünge des Vereins fanden 1965 aus einer geliehenen Cessna unter Rundkappen aus Armeebeständen statt. 1982 zogen wir auf unseren heutigen Graspiste-Flugplatz um, 2003 nahmen wir unser erstes Turbinenflugzeug in Betrieb, und 2019 begrüßten wir unseren 10 000. Tandempassagier. In all den Jahren ist der Verein ein ehrenamtlich geführter Verein geblieben — Lehrer, Packer, Piloten und Bodenpersonal geben ihre Zeit, damit immer mehr Menschen die Freiheit des Fluges erleben können.',

    ethosEyebrow: 'Unsere Philosophie',
    ethosTitle: 'Sicherheit zuerst. Spaß ganz knapp dahinter.',
    ethosText: 'Wir glauben, dass Fallschirmspringen zugänglich, gut unterrichtet und freudvoll sein soll. Unser Material wird nach den höchsten europäischen Standards gewartet, unsere Lehrer besitzen aktuelle internationale Lizenzen, und unsere Briefings werden nie abgekürzt. Jeden Besucher — ob beim ersten Sprung oder beim 5 000. — behandeln wir vom Moment des Eintreffens am Flugplatz als Teil der Familie.',

    ctaTitle: 'Komm vorbei.',
    ctaSubtitle: 'Das Vereinsheim ist von April bis Oktober jedes Wochenende geöffnet. Auf einen Kaffee, ein Gespräch oder deinen ersten Sprung.',
    ctaPrimary: 'Tandem buchen',
    ctaSecondary: 'Kontakt',
  },
}[lang];

const tandemHref = `/${lang}/tandem`;
const contactHref = `/${lang}/contact`;
---

<PageBanner
  image={bannerImg}
  alt="Skydive Luxembourg dropzone"
  eyebrow={t.bannerEyebrow}
  title={t.bannerTitle}
  subtitle={t.bannerSubtitle}
/>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.introEyebrow}</p>
      <h2 class="section__title">{t.introTitle}</h2>
      <p class="section__lead">{t.introText}</p>
    </header>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner">
    <header class="section__header">
      <p class="section__eyebrow">{t.whatEyebrow}</p>
      <h2 class="section__title">{t.whatTitle}</h2>
      <p class="section__lead">{t.whatLead}</p>
    </header>
    <FeatureCards items={t.cards} />
  </div>
</section>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.historyEyebrow}</p>
      <h2 class="section__title">{t.historyTitle}</h2>
      <p class="section__lead">{t.historyText}</p>
    </header>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.ethosEyebrow}</p>
      <h2 class="section__title">{t.ethosTitle}</h2>
      <p class="section__lead">{t.ethosText}</p>
    </header>
  </div>
</section>

<CTABanner
  title={t.ctaTitle}
  subtitle={t.ctaSubtitle}
  primaryCta={{ label: t.ctaPrimary, href: tandemHref }}
  secondaryCta={{ label: t.ctaSecondary, href: contactHref }}
/>
