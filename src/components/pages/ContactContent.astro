---
/**
 * ContactContent.astro - Contact page. Picks copy by `lang` prop.
 */
import PageBanner from '../sections/PageBanner.astro';
import ContactForm from '../ContactForm.astro';

import bannerImg from '../../assets/img/Contact-1.jpg';

const { lang = 'en' } = Astro.props;

const t = {
  en: {
    eyebrow: 'Get in touch',
    title: 'Contact us',
    subtitle: 'Questions, bookings, group enquiries: we read every message.',
    infoEyebrow: 'Find us',
    infoTitle: 'Skydive Luxembourg a.s.b.l.',
    infoIntro: 'Our dropzone operates from a private grass airfield in the north of the country. You can reach us by car in 25 minutes from Luxembourg City.',
    addressLabel: 'Address',
    addressLines: ['32 Op der Louh', 'L-9676 Noertrange', 'Luxembourg'],
    emailLabel: 'Email',
    phoneLabel: 'Phone',
    hoursLabel: 'Opening hours',
    hoursLines: ['Weekends, April to October', '09:00 – 18:00'],
    hoursNote: 'Outside the main season we operate on request only. Please contact us in advance.',
    formEyebrow: 'Write to us',
    formTitle: 'Send a message',
    formLead: 'For tandem bookings, AFF enquiries, group reservations or anything else, fill in the form below and we\'ll reply within two to three business days.',
    directionsTitle: 'How to get here',
    directionsText: 'From Luxembourg City, take the A7 north towards Ettelbruck/Wiltz, then continue to Noertrange/Winseler. The dropzone is at 32 Op der Louh, near Noertrange airfield. Free parking is available on site.',
    mapTitle: 'Map of Noertrange airfield',
  },

  fr: {
    eyebrow: 'Nous joindre',
    title: 'Contact',
    subtitle: 'Questions, réservations, groupes - nous lisons chaque message.',
    infoEyebrow: 'Nous trouver',
    infoTitle: 'Skydive Luxembourg a.s.b.l.',
    infoIntro: 'Notre dropzone opère depuis un aérodrome privé en herbe dans le nord du pays. Comptez 25 minutes en voiture depuis Luxembourg-Ville.',
    addressLabel: 'Adresse',
    addressLines: ['32 Op der Louh', 'L-9676 Noertrange', 'Luxembourg'],
    emailLabel: 'Courriel',
    phoneLabel: 'Téléphone',
    hoursLabel: 'Horaires d\'ouverture',
    hoursLines: ['Week-ends, d\'avril à octobre', '09h00 – 18h00'],
    hoursNote: 'Hors saison principale, nous fonctionnons uniquement sur demande - merci de nous prévenir à l\'avance.',
    formEyebrow: 'Écrivez-nous',
    formTitle: 'Envoyer un message',
    formLead: 'Pour les réservations tandem, les demandes AFF, les groupes ou toute autre question, remplissez le formulaire ci-dessous. Nous répondrons dans un délai de deux à trois jours ouvrables.',
    directionsTitle: 'Comment nous rejoindre',
    directionsText: 'Depuis Luxembourg-Ville, prenez l\'A7 vers le nord en direction d\'Ettelbruck/Wiltz, puis continuez vers Noertrange/Winseler. La DZ se trouve au 32 Op der Louh, près de l\'aérodrome de Noertrange. Parking gratuit sur place.',
    mapTitle: 'Carte de l\'aérodrome de Noertrange',
  },

  de: {
    eyebrow: 'Kontakt',
    title: 'Kontakt aufnehmen',
    subtitle: 'Fragen, Buchungen, Gruppenanfragen - wir lesen jede Nachricht.',
    infoEyebrow: 'So findest du uns',
    infoTitle: 'Skydive Luxembourg a.s.b.l.',
    infoIntro: 'Unsere Dropzone befindet sich auf einem privaten Grasflugplatz im Norden des Landes. Von Luxemburg-Stadt sind es etwa 25 Autominuten.',
    addressLabel: 'Adresse',
    addressLines: ['32 Op der Louh', 'L-9676 Noertrange', 'Luxemburg'],
    emailLabel: 'E-Mail',
    phoneLabel: 'Telefon',
    hoursLabel: 'Öffnungszeiten',
    hoursLines: ['Wochenenden, April bis Oktober', '09:00 – 18:00 Uhr'],
    hoursNote: 'Außerhalb der Hauptsaison nur nach Vereinbarung - bitte vorab Kontakt aufnehmen.',
    formEyebrow: 'Schreib uns',
    formTitle: 'Nachricht senden',
    formLead: 'Für Tandembuchungen, AFF-Anfragen, Gruppenreservierungen oder andere Anliegen - fülle einfach das Formular aus. Wir antworten innerhalb von zwei bis drei Werktagen.',
    directionsTitle: 'Anfahrt',
    directionsText: 'Von Luxemburg-Stadt nimm die A7 Richtung Norden nach Ettelbruck/Wiltz und fahre weiter nach Noertrange/Winseler. Die Dropzone liegt in 32 Op der Louh, nahe dem Flugplatz Noertrange. Kostenlose Parkplätze sind vor Ort verfügbar.',
    mapTitle: 'Karte des Flugplatzes Noertrange',
  },
}[lang];

const email = 'mail@skydive.lu';
const phone = '+352 621 701 194 (SMS or WhatsApp only; phone calls by appointment)';
const phoneHref = 'tel:+352621701194';
---

<PageBanner
  image={bannerImg}
  alt="Skydive Luxembourg dropzone office"
  imagePosition="center 36%"
  eyebrow={t.eyebrow}
  title={t.title}
  subtitle={t.subtitle}
/>

<section class="section">
  <div class="section__inner">
    <div class="grid grid--2 contact-grid">
      <div class="contact-info">
        <p class="section__eyebrow">{t.infoEyebrow}</p>
        <h2 class="section__title">{t.infoTitle}</h2>
        <p class="section__lead">{t.infoIntro}</p>

        <dl class="contact-info__list">
          <dt>{t.addressLabel}</dt>
          <dd>
            {t.addressLines.map((line, i) => (
              <>{line}{i < t.addressLines.length - 1 && <br />}</>
            ))}
          </dd>

          <dt>{t.emailLabel}</dt>
          <dd><a href={`mailto:${email}`}>{email}</a></dd>

          <dt>{t.phoneLabel}</dt>
          <dd><a href={phoneHref}>{phone}</a></dd>

          <dt>{t.hoursLabel}</dt>
          <dd>
            {t.hoursLines.map((line, i) => (
              <>{line}{i < t.hoursLines.length - 1 && <br />}</>
            ))}
            <br /><small>{t.hoursNote}</small>
          </dd>
        </dl>
      </div>

      <div class="contact-form-wrap">
        <p class="section__eyebrow">{t.formEyebrow}</p>
        <h2 class="section__title">{t.formTitle}</h2>
        <p class="section__lead">{t.formLead}</p>
        <ContactForm lang={lang} />
      </div>
    </div>
  </div>
</section>

<section class="section section--alt section--tight">
  <div class="section__inner">
    <h2 class="section__title">{t.directionsTitle}</h2>
    <p class="section__lead">{t.directionsText}</p>
    <div class="contact-map">
      <iframe
        title={t.mapTitle}
        src="https://www.google.com/maps?q=Noertrange,+Luxembourg&output=embed"
        width="100%"
        height="420"
        style="border:0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    gap: var(--space-10);
    align-items: start;
  }

  .contact-info__list {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-3) var(--space-6);
  }
  .contact-info__list dt {
    font-weight: var(--fw-medium);
    color: var(--color-fg);
  }
  .contact-info__list dd {
    margin: 0;
    color: var(--color-fg-muted);
  }
  .contact-info__list a {
    color: var(--color-blue);
    text-decoration: none;
  }
  .contact-info__list a:hover {
    text-decoration: underline;
  }

  .contact-map {
    margin-top: var(--space-6);
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
</style>
