---
/**
 * ImprintContent.astro — Legal imprint page. Picks copy by `lang` prop.
 */
import PageBanner from '../sections/PageBanner.astro';

import bannerImg from '../../assets/img/Hero-2.jpg';

const { lang = 'en' } = Astro.props;

const t = {
  en: {
    eyebrow: 'Legal information',
    title: 'Imprint',
    subtitle: 'Mandatory legal information for this website.',
  },

  fr: {
    eyebrow: 'Mentions légales',
    title: 'Mentions légales',
    subtitle: 'Informations légales obligatoires concernant ce site.',
  },

  de: {
    eyebrow: 'Rechtliche Hinweise',
    title: 'Impressum',
    subtitle: 'Gesetzlich vorgeschriebene Angaben zu dieser Website.',
  },
}[lang];
---

<PageBanner
  image={bannerImg}
  alt="Skydive Luxembourg airfield from above"
  eyebrow={t.eyebrow}
  title={t.title}
  subtitle={t.subtitle}
/>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <div class="prose">
      {lang === 'en' && (
        <>
          <h2>Publisher</h2>
          <p>
            <strong>Skydive Luxembourg a.s.b.l.</strong><br />
            Aérodrome de Useldange<br />
            L-8707 Useldange<br />
            Grand Duchy of Luxembourg
          </p>
          <p>
            Registered as a non-profit association (association sans but lucratif)<br />
            RCS Luxembourg: F-XXXX<br />
            Email: <a href="mailto:info@skydive.lu">info@skydive.lu</a><br />
            Phone: +352 621 234 567
          </p>

          <h2>Responsible for content</h2>
          <p>
            John Doe, President of the Board<br />
            On behalf of Skydive Luxembourg a.s.b.l.<br />
            Email: <a href="mailto:info@skydive.lu">info@skydive.lu</a>
          </p>

          <h2>Board</h2>
          <p>
            The association is governed by an elected board of volunteers, including a President, a Vice-President, a Treasurer, a Secretary, and additional members. Members can be reached through the official email address above.
          </p>

          <h2>Hosting provider</h2>
          <p>
            This website is hosted by:<br />
            <strong>Netlify, Inc.</strong><br />
            44 Montgomery Street, Suite 300<br />
            San Francisco, CA 94104, USA
