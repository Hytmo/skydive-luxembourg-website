      {lang === 'fr' && (
        <>
          <h2>Éditeur</h2>
          <p>
            <strong>Skydive Luxembourg a.s.b.l.</strong><br />
            Aérodrome de Useldange<br />
            L-8707 Useldange<br />
            Grand-Duché de Luxembourg
          </p>
          <p>
            Association sans but lucratif déclarée<br />
            RCS Luxembourg : F-XXXX<br />
            Courriel : <a href="mailto:info@skydive.lu">info@skydive.lu</a><br />
            Téléphone : +352 621 234 567
          </p>

          <h2>Responsable de la publication</h2>
