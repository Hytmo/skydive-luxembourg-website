---
/**
 * TandemContent.astro — tandem jump page body. Picks copy by `lang` prop.
 */
import PageBanner from '../sections/PageBanner.astro';
import FeatureCards from '../sections/FeatureCards.astro';
import CTABanner from '../sections/CTABanner.astro';

import bannerImg from '../../assets/img/Tandem-2.jpg';
import step1Img from '../../assets/img/Tandem-1.jpg';
import step2Img from '../../assets/img/Tandem-3.jpg';
import step3Img from '../../assets/img/Tandem-4.jpg';

const BOOKING_URL = 'https://cpl.dz-cloud.com/en/Booking/s1_Options';

const { lang = 'en' } = Astro.props;

const t = {
  en: {
    bannerEyebrow: 'Tandem skydive',
    bannerTitle: 'Your first jump — strapped to a pro.',
    bannerSubtitle: 'Freefall from 4,000 metres above the Moselle valley. No experience required.',

    introEyebrow: 'What is a tandem jump?',
    introTitle: 'The easiest way to skydive.',
    introText: 'A tandem skydive lets you experience the full thrill of freefall on your very first jump. You are securely harnessed to one of our qualified tandem masters — an instructor with thousands of jumps and an internationally recognised tandem rating. They look after everything: the equipment, the exit, the freefall, the canopy flight and the landing. Your job is to relax, breathe, and enjoy the view. From the moment you arrive on the dropzone to the moment you land back, expect to spend around three hours with us.',

    expectEyebrow: 'What to expect',
    expectTitle: 'Three steps from ground to ground.',
    expectLead: 'A clear, well-paced experience designed to make your first jump unforgettable for the right reasons.',

    steps: [
      { title: '1. Briefing & gear-up', text: 'On arrival we sign you in, weigh you, then walk you through a 15-minute briefing covering the exit, the freefall position and the landing. Your instructor fits your harness and double-checks every buckle before you board.', image: step1Img, alt: 'Tandem briefing on the ground' },
      { title: '2. Climb to altitude', text: 'Our Cessna 208 Caravan takes around 15 minutes to reach 4,000 metres. Take in the view of Luxembourg, France and Germany through the windows — and try not to think too hard about what comes next.', image: step2Img, alt: 'View from the aircraft on the climb' },
      { title: '3. Freefall & canopy', text: 'About 50 seconds of freefall at 200 km/h, then your instructor opens the canopy at around 1,500 metres for a calm 5-minute glide back to the dropzone. You\'ll even get a chance to steer.', image: step3Img, alt: 'Open canopy on the descent' },
    ],

    reqEyebrow: 'Requirements',
    reqTitle: 'Can I jump?',
    reqLead: 'Most adults in reasonable health can. Please read through the points below — if anything is unclear, get in touch before booking.',
    reqs: [
      'Minimum age 16. Under-18s need a parent or guardian to sign the consent form.',
      'Maximum body weight 100 kg, fully clothed.',
      'No serious heart, back or neurological conditions; no recent surgery. If unsure, ask your GP.',
      'Pregnant passengers cannot jump. Please reschedule.',
      'No alcohol in the previous 12 hours.',
    ],

    bookEyebrow: 'Booking',
    bookTitle: 'Pick a date and we\'ll see you on the dropzone.',
    bookText: 'Bookings are handled through our online manifest system. You\'ll choose a date, an arrival window, and any add-ons (video, photos, group package). A 50 % deposit secures your slot. If the weather doesn\'t play along, we\'ll happily reschedule — your deposit is never lost.',
    bookCta: 'Book your tandem',

    bringEyebrow: 'On the day',
    bringTitle: 'What to bring.',
    bringList: [
      'Photo ID (passport or national ID).',
      'Comfortable, weather-appropriate clothing. Layers in spring and autumn.',
      'Trainers or light boots with ankle support. No sandals or open shoes.',
      'Glasses are fine — we provide goggles that fit over them.',
      'A good night\'s sleep and a light meal beforehand.',
    ],

    ctaTitle: 'Ready to feel the sky?',
    ctaSubtitle: 'Summer weekends book out fast. Lock in your jump now.',
    ctaPrimary: 'Book a tandem',
    ctaSecondary: 'Questions? Contact us',
  },

  fr: {
    bannerEyebrow: 'Saut en tandem',
    bannerTitle: 'Votre premier saut, attaché à un pro.',
    bannerSubtitle: 'Chute libre depuis 4 000 mètres au-dessus de la vallée de la Moselle. Aucune expérience requise.',

    introEyebrow: 'Qu\'est-ce qu\'un saut en tandem ?',
    introTitle: 'La façon la plus simple de sauter.',
    introText: 'Le saut en tandem vous fait vivre toute l\'intensité de la chute libre dès le premier saut. Vous êtes solidement harnaché à l\'un de nos moniteurs tandem qualifiés — un instructeur cumulant des milliers de sauts et titulaire d\'une qualification tandem internationale. Il s\'occupe de tout : matériel, sortie, chute libre, vol sous voile et atterrissage. Votre rôle ? Vous détendre, respirer et profiter du paysage. Comptez environ trois heures sur place, de votre arrivée à votre atterrissage.',

    expectEyebrow: 'Comment ça se passe',
    expectTitle: 'Trois étapes, du sol au sol.',
    expectLead: 'Un déroulé clair et bien rythmé pour que votre premier saut reste inoubliable, pour les bonnes raisons.',

    steps: [
      { title: '1. Briefing et équipement', text: 'À votre arrivée, nous procédons à l\'enregistrement, à la pesée, puis à un briefing de 15 minutes : la sortie, la position en chute, l\'atterrissage. Votre moniteur ajuste le harnais et vérifie chaque boucle avant l\'embarquement.', image: step1Img, alt: 'Briefing tandem au sol' },
      { title: '2. Montée en altitude', text: 'Notre Cessna 208 Caravan met environ 15 minutes pour atteindre 4 000 mètres. Admirez le Luxembourg, la France et l\'Allemagne par les hublots — et essayez de ne pas trop penser à la suite.', image: step2Img, alt: 'Vue depuis l\'avion pendant la montée' },
      { title: '3. Chute libre et voile', text: 'Environ 50 secondes de chute libre à 200 km/h, puis ouverture de la voile vers 1 500 mètres pour 5 minutes de vol tranquille jusqu\'à la DZ. Vous aurez même l\'occasion de piloter.', image: step3Img, alt: 'Voile ouverte pendant la descente' },
    ],

    reqEyebrow: 'Conditions',
    reqTitle: 'Puis-je sauter ?',
    reqLead: 'La plupart des adultes en bonne santé le peuvent. Lisez les points ci-dessous — au moindre doute, contactez-nous avant de réserver.',
    reqs: [
      'Âge minimum : 16 ans. Les mineurs doivent fournir une autorisation parentale signée.',
      'Poids maximum : 100 kg habillé.',
      'Pas de pathologies cardiaques, dorsales ou neurologiques sérieuses ; pas de chirurgie récente. En cas de doute, demandez à votre médecin.',
      'Le saut est contre-indiqué en cas de grossesse. Merci de reporter.',
      'Aucun alcool dans les 12 heures précédant le saut.',
    ],

    bookEyebrow: 'Réservation',
    bookTitle: 'Choisissez une date — on vous attend sur la DZ.',
    bookText: 'Les réservations se font via notre système de manifest en ligne. Vous choisissez une date, un créneau d\'arrivée et vos options (vidéo, photos, formule de groupe). Un acompte de 50 % confirme votre place. Si la météo ne coopère pas, nous reprogrammons sans frais — votre acompte n\'est jamais perdu.',
    bookCta: 'Réserver mon tandem',

    bringEyebrow: 'Le jour J',
    bringTitle: 'Quoi prendre avec vous.',
    bringList: [
      'Une pièce d\'identité avec photo (passeport ou carte d\'identité).',
      'Des vêtements confortables et adaptés à la météo. Pensez aux couches au printemps et en automne.',
      'Des baskets ou chaussures montantes avec maintien de cheville. Pas de sandales ni de chaussures ouvertes.',
      'Les lunettes de vue ne posent aucun problème — nos masques se mettent par-dessus.',
      'Une bonne nuit de sommeil et un repas léger avant de venir.',
    ],

    ctaTitle: 'Prêt à sentir le ciel ?',
    ctaSubtitle: 'Les week-ends d\'été partent vite. Réservez dès maintenant.',
    ctaPrimary: 'Réserver un tandem',
    ctaSecondary: 'Une question ? Contactez-nous',
  },

  de: {
    bannerEyebrow: 'Tandemsprung',
    bannerTitle: 'Dein erster Sprung — angeschnallt an einen Profi.',
    bannerSubtitle: 'Freier Fall aus 4 000 Metern über dem Moseltal. Keine Vorkenntnisse nötig.',

    introEyebrow: 'Was ist ein Tandemsprung?',
    introTitle: 'Der einfachste Weg, Fallschirm zu springen.',
    introText: 'Beim Tandemsprung erlebst du den vollen Nervenkitzel des freien Falls schon beim allerersten Sprung. Du bist sicher an einen unserer geprüften Tandemmaster geschnallt — einen Lehrer mit tausenden Sprüngen und einer international anerkannten Tandemlizenz. Er kümmert sich um alles: Material, Ausstieg, freier Fall, Schirmflug und Landung. Deine Aufgabe: entspannen, atmen, die Aussicht genießen. Vom Ankommen bis zur Landung solltest du rund drei Stunden auf dem Flugplatz einplanen.',

    expectEyebrow: 'Was dich erwartet',
    expectTitle: 'Drei Schritte vom Boden zum Boden.',
    expectLead: 'Ein klarer, gut getakteter Ablauf, damit dein erster Sprung aus den richtigen Gründen unvergesslich wird.',

    steps: [
      { title: '1. Briefing und Anlegen', text: 'Bei der Ankunft melden wir dich an, wiegen dich und geben dir ein 15-minütiges Briefing zu Ausstieg, Fallhaltung und Landung. Dein Lehrer passt den Gurt an und kontrolliert vor dem Einsteigen jede einzelne Schnalle.', image: step1Img, alt: 'Tandem-Briefing am Boden' },
      { title: '2. Steigflug', text: 'Unsere Cessna 208 Caravan braucht etwa 15 Minuten bis auf 4 000 Meter. Genieße den Blick auf Luxemburg, Frankreich und Deutschland — und versuche, nicht zu sehr darüber nachzudenken, was als Nächstes kommt.', image: step2Img, alt: 'Blick aus dem Flugzeug beim Steigflug' },
      { title: '3. Freier Fall und Schirm', text: 'Etwa 50 Sekunden freier Fall bei 200 km/h, dann öffnet dein Lehrer den Schirm auf rund 1 500 Metern für einen ruhigen 5-Minuten-Gleitflug zurück zum Flugplatz. Du darfst sogar selbst steuern.', image: step3Img, alt: 'Offener Schirm beim Abstieg' },
    ],

    reqEyebrow: 'Voraussetzungen',
    reqTitle: 'Darf ich springen?',
    reqLead: 'Die meisten gesunden Erwachsenen können das. Bitte lies die Punkte unten — wenn etwas unklar ist, melde dich vor der Buchung bei uns.',
    reqs: [
      'Mindestalter 16 Jahre. Unter 18 Jahren ist die Einverständniserklärung eines Erziehungsberechtigten nötig.',
      'Höchstgewicht 100 kg in voller Bekleidung.',
      'Keine schweren Herz-, Rücken- oder neurologischen Erkrankungen; keine kürzlich erfolgte Operation. Im Zweifel bitte Hausarzt fragen.',
      'Schwangere Passagierinnen dürfen nicht springen. Bitte verschiebe den Termin.',
      'Kein Alkohol in den 12 Stunden vor dem Sprung.',
    ],

    bookEyebrow: 'Buchung',
    bookTitle: 'Wähle ein Datum — wir sehen uns am Flugplatz.',
    bookText: 'Buchungen laufen über unser Online-Manifest. Du wählst Datum, Ankunftsfenster und Zusatzoptionen (Video, Fotos, Gruppen-Paket). Eine Anzahlung von 50 % sichert dir deinen Slot. Spielt das Wetter nicht mit, verschieben wir gerne — die Anzahlung verfällt nie.',
    bookCta: 'Tandem buchen',

    bringEyebrow: 'Am Sprungtag',
    bringTitle: 'Was du mitbringst.',
    bringList: [
      'Einen Lichtbildausweis (Reisepass oder Personalausweis).',
      'Bequeme, wettergerechte Kleidung. Im Frühling und Herbst Zwiebellook.',
      'Turnschuhe oder leichte Stiefel mit Knöchelhalt. Keine Sandalen oder offenen Schuhe.',
      'Brillen sind kein Problem — unsere Schutzbrillen passen darüber.',
      'Eine gute Nacht Schlaf und eine leichte Mahlzeit vorher.',
    ],

    ctaTitle: 'Bereit, den Himmel zu spüren?',
    ctaSubtitle: 'Sommerwochenenden sind schnell ausgebucht. Sichere dir deinen Sprung jetzt.',
    ctaPrimary: 'Tandem buchen',
    ctaSecondary: 'Fragen? Kontakt',
  },
}[lang];

const contactHref = `/${lang}/contact`;
---

<PageBanner
  image={bannerImg}
  alt="Tandem skydive over Luxembourg"
  eyebrow={t.bannerEyebrow}
  title={t.bannerTitle}
  subtitle={t.bannerSubtitle}
/>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.introEyebrow}</p>
      <h2 class="section__title">{t.introTitle}</h2>
      <p class="section__lead">{t.introText}</p>
    </header>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner">
    <header class="section__header">
      <p class="section__eyebrow">{t.expectEyebrow}</p>
      <h2 class="section__title">{t.expectTitle}</h2>
      <p class="section__lead">{t.expectLead}</p>
    </header>
    <FeatureCards items={t.steps} />
  </div>
</section>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.reqEyebrow}</p>
      <h2 class="section__title">{t.reqTitle}</h2>
      <p class="section__lead">{t.reqLead}</p>
    </header>
    <div class="req-box">
      <ul>
        {t.reqs.map((r) => <li>{r}</li>)}
      </ul>
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.bookEyebrow}</p>
      <h2 class="section__title">{t.bookTitle}</h2>
      <p class="section__lead">{t.bookText}</p>
      <p style="margin-top: var(--space-6)">
        <a href={BOOKING_URL} class="btn btn--primary btn--lg" target="_blank" rel="noopener noreferrer">{t.bookCta}</a>
      </p>
    </header>
  </div>
</section>

<section class="section">
  <div class="section__inner section__inner--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{t.bringEyebrow}</p>
      <h2 class="section__title">{t.bringTitle}</h2>
    </header>
    <div class="bring-list">
      <ul>
        {t.bringList.map((b) => <li>{b}</li>)}
      </ul>
    </div>
  </div>
</section>

<CTABanner
  title={t.ctaTitle}
  subtitle={t.ctaSubtitle}
  primaryCta={{ label: t.ctaPrimary, href: BOOKING_URL }}
  secondaryCta={{ label: t.ctaSecondary, href: contactHref }}
/>

<style>
  .req-box,
  .bring-list {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
  }
  .req-box ul,
  .bring-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .req-box li,
  .bring-list li {
    padding-left: var(--space-6);
    position: relative;
    color: var(--color-fg-muted);
  }
  .req-box li::before,
  .bring-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-blue);
    font-weight: var(--fw-bold);
  }
</style>
