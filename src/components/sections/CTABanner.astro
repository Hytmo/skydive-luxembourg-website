---
/**
 * CTABanner.astro - full-bleed call-to-action strip with colored bg.
 * Props: title, subtitle, primaryCta, secondaryCta
 */
const { title, subtitle, primaryCta, secondaryCta } = Astro.props;
---

<section class="cta-banner">
  <div class="cta-banner__inner">
    <h2 class="cta-banner__title">{title}</h2>
    {subtitle && <p class="cta-banner__subtitle">{subtitle}</p>}
    <div class="cta-banner__ctas">
      {primaryCta && (
        <a
          href={primaryCta.href}
          class="btn btn--primary btn--lg"
          {...(primaryCta.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >{primaryCta.label}</a>
      )}
      {secondaryCta && (
        <a href={secondaryCta.href} class="btn btn--ghost btn--lg">{secondaryCta.label}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-banner {
    background: var(--color-surface-inverse);
    color: var(--color-on-inverse);
    padding: var(--space-16) var(--space-4);
    text-align: center;
  }

  .cta-banner__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .cta-banner__title {
    font-size: var(--fs-2xl);
    margin-bottom: var(--space-3);
    text-wrap: balance;
  }

  .cta-banner__subtitle {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-8);
    color: var(--color-on-inverse-muted);
  }

  .cta-banner__ctas {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }
</style>
