---
/**
 * PriceCards.astro - pricing tier grid.
 * Props:
 *   items: Array<{ title, price, priceNote?, description?, features: string[],
 *                  cta?: { label, href }, featured?: boolean }>
 */
const { items = [] } = Astro.props;
---

<div class="price-grid">
  {items.map((item) => (
    <article class={`price-card${item.featured ? ' price-card--featured' : ''}`}>
      <h3 class="price-card__title">{item.title}</h3>
      <p class="price-card__price">
        <span class="price-card__amount">{item.price}</span>
        {item.priceNote && <span class="price-card__note">{item.priceNote}</span>}
      </p>
      {item.description && <p class="price-card__desc">{item.description}</p>}
      <ul class="price-card__features">
        {item.features.map((f) => <li>{f}</li>)}
      </ul>
      {item.cta && (
        <a
          href={item.cta.href}
          class={`btn ${item.featured ? 'btn--primary' : 'btn--outline'}`}
          {...(item.cta.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {item.cta.label}
        </a>
      )}
    </article>
  ))}
</div>

<style>
  .price-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    align-items: stretch;
  }
  @media (max-width: 900px) {
    .price-grid { grid-template-columns: 1fr; }
  }

  .price-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .price-card--featured {
    border-color: var(--color-cta);
    box-shadow: var(--shadow-lg);
    position: relative;
  }

  .price-card__title {
    font-size: var(--fs-xl);
  }

  .price-card__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .price-card__amount {
    font-size: var(--fs-3xl);
    font-weight: var(--fw-bold);
    color: var(--color-fg);
    line-height: 1;
  }
  .price-card__note {
    color: var(--color-fg-muted);
    font-size: var(--fs-sm);
  }

  .price-card__desc {
    color: var(--color-fg-muted);
  }

  .price-card__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .price-card__features li {
    padding-left: var(--space-6);
    position: relative;
  }
  .price-card__features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-blue);
    font-weight: var(--fw-bold);
  }

  .price-card .btn {
    margin-top: var(--space-2);
    width: 100%;
  }
</style>
