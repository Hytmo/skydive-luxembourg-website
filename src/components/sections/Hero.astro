---
/**
 * Hero.astro — full-bleed homepage hero.
 * Props: image (imported asset), alt, eyebrow, title, subtitle,
 *        primaryCta { label, href }, secondaryCta { label, href }
 */
import { Image } from 'astro:assets';

const {
  image,
  alt = '',
  eyebrow,
  title,
  subtitle,
  primaryCta,
  secondaryCta,
} = Astro.props;
---

<section class="hero">
  {image && (
    <Image src={image} alt={alt} class="hero__img" widths={[800, 1200, 1800, 2400]} sizes="100vw" loading="eager" />
  )}
  <div class="hero__overlay"></div>

  <div class="hero__inner">
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <h1 class="hero__title">{title}</h1>
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}

    {(primaryCta || secondaryCta) && (
      <div class="hero__ctas">
        {primaryCta && (
          <a href={primaryCta.href} class="btn btn--primary btn--lg">{primaryCta.label}</a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn--ghost btn--lg">{secondaryCta.label}</a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-on-inverse);
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.55) 100%
    );
    z-index: -1;
  }

  .hero__inner {
    max-width: 820px;
    padding: var(--space-16) var(--space-4);
  }

  .hero__eyebrow {
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-blue);
    margin-bottom: var(--space-4);
  }

  .hero__title {
    font-size: var(--fs-4xl);
    line-height: 1.05;
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .hero__subtitle {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-8);
    opacity: 0.95;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__ctas {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }

  @media (max-width: 700px) {
    .hero { min-height: 70vh; }
    .hero__title { font-size: var(--fs-3xl); }
    .hero__subtitle { font-size: var(--fs-base); }
  }
</style>
